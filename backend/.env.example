# Copy this file to .env and fill in real values before running the server.

# The one owner account that can access the backend dashboard.
OWNER_EMAIL=htenterprisesofficial@gmail.com
OWNER_PASSWORD=*htgroup8*

# Used to sign login sessions (JWTs). Set this to a long random string in production.
JWT_SECRET=change-this-to-a-long-random-string

# WhatsApp order notifications (via Twilio). Optional — if left blank, the
# backend just skips sending the message (orders still work normally).
# See the README for how to get these from a free Twilio account.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
OWNER_WHATSAPP_NUMBER=+923134618471
